---
import "../styles/global.css";

const inputClass =
  "w-full min-h-11 rounded-lg border border-sand-500 bg-white px-3.5 text-base text-ink placeholder:text-sand-600 transition focus:border-coral-500 focus:outline-none focus:ring-2 focus:ring-coral-500/40";
const labelClass = "block text-sm font-medium text-sand-700 mb-1.5";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Voia admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Plus+Jakarta+Sans:wght@400..700&display=swap"
    />
  </head>
  <body>
    <!-- Signed out: centered login card -->
    <main id="signed-out" class="hidden min-h-screen items-center justify-center px-6 py-12 sm:px-8">
      <div class="w-full max-w-sm rounded-2xl bg-white p-6 shadow-card sm:p-8">
        <h1 class="font-display text-2xl font-bold tracking-tight text-ink">Voia admin</h1>
        <p class="mt-1 text-sm text-sand-700">Sign in to view enquiries and chat transcripts.</p>

        <form id="login-form" novalidate class="mt-6 space-y-5">
          <div>
            <label for="email" class={labelClass}>
              Email <span class="font-normal text-sand-500">(required)</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="username"
              aria-describedby="login-error"
              class={inputClass}
            />
          </div>
          <div>
            <label for="password" class={labelClass}>
              Password <span class="font-normal text-sand-500">(required)</span>
            </label>
            <input
              id="password"
              name="password"
              type="password"
              required
              autocomplete="current-password"
              aria-describedby="login-error"
              class={inputClass}
            />
          </div>

          <p id="login-error" class="hidden items-start gap-1.5 text-sm text-error-700" role="alert" aria-live="assertive">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" class="mt-0.5 h-4 w-4 shrink-0">
              <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <span></span>
          </p>

          <button
            type="submit"
            id="login-submit"
            class="inline-flex w-full min-h-11 items-center justify-center gap-2 rounded-lg bg-coral-600 px-5 font-semibold text-white transition-colors hover:bg-coral-700 active:bg-coral-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none"
          >
            Sign in
          </button>
        </form>
      </div>
    </main>

    <!-- Signed in: header + logout + read-only lists -->
    <div id="signed-in" class="hidden min-h-screen">
      <header class="mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-6 sm:px-8">
        <h1 class="font-display text-2xl font-bold tracking-tight text-ink">Voia admin</h1>
        <button
          type="button"
          id="logout-btn"
          class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg bg-white px-5 font-semibold text-teal-700 ring-1 ring-teal-600 transition-colors hover:bg-teal-50 active:bg-teal-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
        >
          Logout
        </button>
      </header>

      <main class="mx-auto w-full max-w-5xl px-6 pb-16 sm:px-8">
        <section id="enquiries-section" aria-labelledby="enquiries-heading" class="mt-4">
          <h2 id="enquiries-heading" class="font-display text-xl font-semibold tracking-tight text-ink">
            Recent enquiries
          </h2>
          <div id="enquiries-list" class="mt-4"></div>
        </section>

        <section id="contact-section" aria-labelledby="contact-heading" class="mt-12">
          <h2 id="contact-heading" class="font-display text-xl font-semibold tracking-tight text-ink">
            Recent contact messages
          </h2>
          <div id="contact-list" class="mt-4"></div>
        </section>

        <section id="transcripts-section" aria-labelledby="transcripts-heading" class="mt-12">
          <h2 id="transcripts-heading" class="font-display text-xl font-semibold tracking-tight text-ink">
            Recent chat transcripts
          </h2>
          <div id="transcripts-list" class="mt-4"></div>
        </section>
      </main>
    </div>
  </body>
</html>

<script>
  import { supabase } from "../lib/supabase";

  const signedOutView = document.getElementById("signed-out") as HTMLElement;
  const signedInView = document.getElementById("signed-in") as HTMLElement;
  const loginForm = document.getElementById("login-form") as HTMLFormElement;
  const loginSubmit = document.getElementById("login-submit") as HTMLButtonElement;
  const loginError = document.getElementById("login-error") as HTMLElement;
  const emailInput = document.getElementById("email") as HTMLInputElement;
  const passwordInput = document.getElementById("password") as HTMLInputElement;
  const logoutBtn = document.getElementById("logout-btn") as HTMLButtonElement;
  const enquiriesList = document.getElementById("enquiries-list") as HTMLElement;
  const contactList = document.getElementById("contact-list") as HTMLElement;
  const transcriptsList = document.getElementById("transcripts-list") as HTMLElement;

  let enquiriesLoaded = false;
  let contactLoaded = false;
  let transcriptsLoaded = false;

  function showSignedOut() {
    signedInView.classList.add("hidden");
    signedOutView.classList.remove("hidden");
    signedOutView.classList.add("flex");
    enquiriesLoaded = false;
    contactLoaded = false;
    transcriptsLoaded = false;
    // Clear any previously rendered PII from the DOM (e.g. shared computer).
    enquiriesList.textContent = "";
    contactList.textContent = "";
    transcriptsList.textContent = "";
    loginForm.reset();
  }

  function showSignedIn() {
    signedOutView.classList.add("hidden");
    signedOutView.classList.remove("flex");
    signedInView.classList.remove("hidden");
    if (!enquiriesLoaded) {
      enquiriesLoaded = true;
      loadEnquiries();
    }
    if (!contactLoaded) {
      contactLoaded = true;
      loadContactMessages();
    }
    if (!transcriptsLoaded) {
      transcriptsLoaded = true;
      loadTranscripts();
    }
  }

  // ---- Shared read-only list rendering (empty/error states) ----

  function renderEmpty(container: HTMLElement, message: string) {
    container.textContent = "";
    const p = document.createElement("p");
    p.className = "text-sm text-sand-600";
    p.textContent = message;
    container.appendChild(p);
  }

  function renderError(container: HTMLElement, message: string) {
    container.textContent = "";
    const box = document.createElement("div");
    box.className = "rounded-2xl bg-error-50 p-4 text-sm text-error-700";
    box.setAttribute("role", "alert");
    box.textContent = message;
    container.appendChild(box);
  }

  function pill(text: string): HTMLElement {
    const span = document.createElement("span");
    span.className =
      "inline-flex items-center rounded-full bg-sand-100 px-2.5 py-0.5 text-xs font-medium text-sand-700";
    span.textContent = text;
    return span;
  }

  function labeledLine(label: string, value: string): HTMLElement {
    const p = document.createElement("p");
    const strong = document.createElement("span");
    strong.className = "font-medium text-sand-700";
    strong.textContent = `${label}: `;
    const val = document.createElement("span");
    val.textContent = value;
    p.append(strong, val);
    return p;
  }

  function formatDateTime(iso: string): string {
    return new Date(iso).toLocaleString(undefined, { dateStyle: "medium", timeStyle: "short" });
  }

  function formatDateOnly(iso: string | null): string {
    return iso ? new Date(iso).toLocaleDateString(undefined, { dateStyle: "medium" }) : "—";
  }

  // ---- Recent enquiries ----

  interface Enquiry {
    created_at: string;
    name: string;
    email: string;
    trip_title: string | null;
    trip_slug: string | null;
    travel_from: string | null;
    travel_to: string | null;
    adults: number;
    children: number;
    pets: number;
    message: string | null;
    consent: boolean;
    status: string;
  }

  function formatParty(adults: number, children: number, pets: number): string {
    const parts = [`${adults} adult${adults === 1 ? "" : "s"}`];
    if (children) parts.push(`${children} ${children === 1 ? "child" : "children"}`);
    if (pets) parts.push(`${pets} pet${pets === 1 ? "" : "s"}`);
    return parts.join(" · ");
  }

  function enquiryCard(e: Enquiry): HTMLElement {
    const card = document.createElement("div");
    card.className = "rounded-2xl border border-sand-200 bg-white p-4 shadow-sm";

    const top = document.createElement("div");
    top.className = "flex items-start justify-between gap-3";
    const nameWrap = document.createElement("div");
    const nameEl = document.createElement("p");
    nameEl.className = "font-display text-base font-semibold text-ink";
    nameEl.textContent = e.name;
    const emailEl = document.createElement("p");
    emailEl.className = "text-sm text-sand-600";
    emailEl.textContent = e.email;
    nameWrap.append(nameEl, emailEl);
    top.append(nameWrap, pill(e.status));
    card.appendChild(top);

    const dateEl = document.createElement("p");
    dateEl.className = "mt-2 text-xs text-sand-600";
    dateEl.textContent = formatDateTime(e.created_at);
    card.appendChild(dateEl);

    const details = document.createElement("div");
    details.className = "mt-3 space-y-1 text-sm text-sand-700";
    details.append(
      labeledLine("Trip", e.trip_title ? `${e.trip_title}${e.trip_slug ? ` (${e.trip_slug})` : ""}` : "—"),
      labeledLine("Dates", `${formatDateOnly(e.travel_from)} → ${formatDateOnly(e.travel_to)}`),
      labeledLine("Party", formatParty(e.adults, e.children, e.pets)),
      labeledLine("Consent", e.consent ? "Yes" : "No"),
    );
    card.appendChild(details);

    if (e.message) {
      const msg = document.createElement("p");
      msg.className = "mt-3 text-sm text-ink";
      msg.textContent = e.message;
      card.appendChild(msg);
    }

    return card;
  }

  function enquiryRow(e: Enquiry): HTMLElement {
    const tr = document.createElement("tr");
    tr.className = "border-b border-sand-200 align-top";

    function td(text: string): HTMLElement {
      const cell = document.createElement("td");
      cell.className = "py-3 pr-4 text-sand-700";
      cell.textContent = text;
      return cell;
    }

    tr.appendChild(td(formatDateTime(e.created_at)));

    const nameCell = document.createElement("td");
    nameCell.className = "py-3 pr-4";
    const nameStrong = document.createElement("p");
    nameStrong.className = "font-medium text-ink";
    nameStrong.textContent = e.name;
    const emailP = document.createElement("p");
    emailP.className = "text-sand-600";
    emailP.textContent = e.email;
    nameCell.append(nameStrong, emailP);
    tr.appendChild(nameCell);

    tr.appendChild(td(e.trip_title ? `${e.trip_title}${e.trip_slug ? ` (${e.trip_slug})` : ""}` : "—"));
    tr.appendChild(td(`${formatDateOnly(e.travel_from)} → ${formatDateOnly(e.travel_to)}`));
    tr.appendChild(td(formatParty(e.adults, e.children, e.pets)));

    const msgCell = document.createElement("td");
    msgCell.className = "max-w-xs py-3 pr-4 whitespace-normal text-sand-700";
    msgCell.textContent = e.message || "—";
    tr.appendChild(msgCell);

    tr.appendChild(td(e.consent ? "Yes" : "No"));

    const statusCell = document.createElement("td");
    statusCell.className = "py-3";
    statusCell.appendChild(pill(e.status));
    tr.appendChild(statusCell);

    return tr;
  }

  function renderEnquiries(container: HTMLElement, rows: Enquiry[]) {
    container.textContent = "";
    if (rows.length === 0) {
      renderEmpty(container, "No enquiries yet.");
      return;
    }

    const cardsWrap = document.createElement("div");
    cardsWrap.className = "space-y-4 md:hidden";
    rows.forEach((e) => cardsWrap.appendChild(enquiryCard(e)));

    const tableWrap = document.createElement("div");
    tableWrap.className = "hidden overflow-x-auto md:block";
    const table = document.createElement("table");
    table.className = "w-full min-w-[720px] border-collapse text-left text-sm";

    const thead = document.createElement("thead");
    const headRow = document.createElement("tr");
    headRow.className = "border-b border-sand-200 text-xs uppercase tracking-wide text-sand-600";
    ["Date", "Name", "Trip", "Dates", "Party", "Message", "Consent", "Status"].forEach((label) => {
      const th = document.createElement("th");
      th.scope = "col";
      th.className = "py-2 pr-4 font-medium";
      th.textContent = label;
      headRow.appendChild(th);
    });
    thead.appendChild(headRow);

    const tbody = document.createElement("tbody");
    rows.forEach((e) => tbody.appendChild(enquiryRow(e)));

    table.append(thead, tbody);
    tableWrap.appendChild(table);
    container.append(cardsWrap, tableWrap);
  }

  async function loadEnquiries() {
    const { data, error } = await supabase
      .from("enquiries")
      .select(
        "created_at,name,email,trip_title,trip_slug,travel_from,travel_to,adults,children,pets,message,consent,status",
      )
      .order("created_at", { ascending: false })
      .limit(50);

    if (error) {
      console.error("Failed to load enquiries:", error);
      renderError(enquiriesList, "Couldn't load enquiries. Please try refreshing the page.");
      return;
    }
    renderEnquiries(enquiriesList, (data ?? []) as Enquiry[]);
  }

  // ---- Recent contact messages ----
  // Optional: reads from contact_messages, which may not exist yet in the
  // live DB (see supabase/contact_messages.sql — "NOT yet run"). Degrades to
  // a neutral empty state rather than an error when the table is missing.

  interface ContactMessage {
    created_at: string;
    name: string;
    email: string;
    subject: string;
    message: string;
    status: string;
  }

  function contactMessageCard(c: ContactMessage): HTMLElement {
    const card = document.createElement("div");
    card.className = "rounded-2xl border border-sand-200 bg-white p-4 shadow-sm";

    const top = document.createElement("div");
    top.className = "flex items-start justify-between gap-3";
    const nameWrap = document.createElement("div");
    const nameEl = document.createElement("p");
    nameEl.className = "font-display text-base font-semibold text-ink";
    nameEl.textContent = c.name;
    const emailEl = document.createElement("p");
    emailEl.className = "text-sm text-sand-600";
    emailEl.textContent = c.email;
    nameWrap.append(nameEl, emailEl);
    top.append(nameWrap, pill(c.status));
    card.appendChild(top);

    const dateEl = document.createElement("p");
    dateEl.className = "mt-2 text-xs text-sand-600";
    dateEl.textContent = formatDateTime(c.created_at);
    card.appendChild(dateEl);

    card.appendChild(labeledLine("Subject", c.subject));

    const msg = document.createElement("p");
    msg.className = "mt-3 text-sm text-ink";
    msg.textContent = c.message;
    card.appendChild(msg);

    return card;
  }

  function renderContactMessages(container: HTMLElement, rows: ContactMessage[]) {
    container.textContent = "";
    if (rows.length === 0) {
      renderEmpty(container, "No contact messages yet.");
      return;
    }
    const wrap = document.createElement("div");
    wrap.className = "space-y-4";
    rows.forEach((c) => wrap.appendChild(contactMessageCard(c)));
    container.appendChild(wrap);
  }

  async function loadContactMessages() {
    const { data, error } = await supabase
      .from("contact_messages")
      .select("created_at,name,email,subject,message,status")
      .order("created_at", { ascending: false })
      .limit(50);

    if (error) {
      // Most likely cause: the table hasn't been created yet — see
      // supabase/contact_messages.sql. Not an operational failure.
      console.error("Failed to load contact messages:", error);
      renderEmpty(
        contactList,
        "No contact messages to show yet — the contact_messages table may not be set up (see supabase/contact_messages.sql).",
      );
      return;
    }
    renderContactMessages(contactList, (data ?? []) as ContactMessage[]);
  }

  // ---- Recent chat transcripts ----

  interface ChatMessage {
    role: "user" | "bot";
    text: string;
  }

  interface ChatTranscript {
    created_at: string;
    session_id: string;
    transcript: unknown;
    interest_tag: string | null;
    status: string;
  }

  function shortenSessionId(sessionId: string): string {
    return sessionId.length > 8 ? `${sessionId.slice(0, 8)}…` : sessionId;
  }

  function isChatMessage(value: unknown): value is ChatMessage {
    if (typeof value !== "object" || value === null) return false;
    const v = value as Record<string, unknown>;
    return (v.role === "user" || v.role === "bot") && typeof v.text === "string";
  }

  function transcriptCard(t: ChatTranscript): HTMLElement {
    const card = document.createElement("div");
    card.className = "rounded-2xl border border-sand-200 bg-white p-4 shadow-sm";

    const top = document.createElement("div");
    top.className = "flex flex-wrap items-center justify-between gap-2";
    const meta = document.createElement("p");
    meta.className = "text-xs text-sand-600";
    meta.textContent = `${formatDateTime(t.created_at)} · session ${shortenSessionId(t.session_id)}`;
    top.append(meta, pill(t.status));
    card.appendChild(top);

    const messages = Array.isArray(t.transcript) ? t.transcript.filter(isChatMessage) : [];
    const bubbles = document.createElement("div");
    bubbles.className = "mt-3 space-y-2";

    if (messages.length === 0) {
      const empty = document.createElement("p");
      empty.className = "text-sm text-sand-600";
      empty.textContent = "No messages recorded.";
      bubbles.appendChild(empty);
    } else {
      messages.forEach((m) => {
        const bubble = document.createElement("div");
        bubble.className =
          m.role === "bot"
            ? "max-w-[85%] rounded-2xl rounded-tl-sm bg-sand-50 px-3.5 py-2.5 text-sm text-ink"
            : "ml-auto max-w-[85%] rounded-2xl rounded-tr-sm bg-coral-600 px-3.5 py-2.5 text-sm text-white";
        bubble.textContent = m.text;
        bubbles.appendChild(bubble);
      });
    }
    card.appendChild(bubbles);

    return card;
  }

  function renderTranscripts(container: HTMLElement, rows: ChatTranscript[]) {
    container.textContent = "";
    if (rows.length === 0) {
      renderEmpty(container, "No chat transcripts yet.");
      return;
    }
    const wrap = document.createElement("div");
    wrap.className = "space-y-4";
    rows.forEach((t) => wrap.appendChild(transcriptCard(t)));
    container.appendChild(wrap);
  }

  async function loadTranscripts() {
    const { data, error } = await supabase
      .from("chat_transcripts")
      .select("created_at,session_id,transcript,interest_tag,status")
      .order("created_at", { ascending: false })
      .limit(50);

    if (error) {
      console.error("Failed to load chat transcripts:", error);
      renderError(transcriptsList, "Couldn't load chat transcripts. Please try refreshing the page.");
      return;
    }
    renderTranscripts(transcriptsList, (data ?? []) as ChatTranscript[]);
  }

  function showLoginError(message: string) {
    emailInput.setAttribute("aria-invalid", "true");
    passwordInput.setAttribute("aria-invalid", "true");
    const span = loginError.querySelector("span");
    if (span) span.textContent = message;
    loginError.classList.remove("hidden");
    loginError.classList.add("flex");
  }

  function clearLoginError() {
    emailInput.removeAttribute("aria-invalid");
    passwordInput.removeAttribute("aria-invalid");
    loginError.classList.add("hidden");
    loginError.classList.remove("flex");
  }

  loginForm.addEventListener("submit", async (event) => {
    event.preventDefault();
    clearLoginError();

    const email = emailInput.value.trim();
    const password = passwordInput.value;
    const originalText = loginSubmit.textContent;
    loginSubmit.disabled = true;
    loginSubmit.textContent = "Signing in…";

    const { error } = await supabase.auth.signInWithPassword({ email, password });

    loginSubmit.disabled = false;
    loginSubmit.textContent = originalText;

    if (error) {
      showLoginError("Incorrect email or password. Please try again.");
    }
    // onAuthStateChange below flips the view to signed-in on success.
  });

  logoutBtn.addEventListener("click", async () => {
    await supabase.auth.signOut();
  });

  supabase.auth.onAuthStateChange((_event, session) => {
    if (session) {
      showSignedIn();
    } else {
      showSignedOut();
    }
  });

  supabase.auth.getSession().then(({ data }) => {
    if (data.session) {
      showSignedIn();
    } else {
      showSignedOut();
    }
  });
</script>
