---
import "../styles/global.css";

const inputClass =
  "w-full min-h-11 rounded-lg border border-sand-500 bg-white px-3.5 text-base text-ink placeholder:text-sand-600 transition focus:border-coral-500 focus:outline-none focus:ring-2 focus:ring-coral-500/40";
const labelClass = "block text-sm font-medium text-sand-700 mb-1.5";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Voia admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Plus+Jakarta+Sans:wght@400..700&display=swap"
    />
  </head>
  <body>
    <!-- Signed out: centered login card -->
    <main id="signed-out" class="hidden min-h-screen items-center justify-center px-6 py-12 sm:px-8">
      <div class="w-full max-w-sm rounded-2xl bg-white p-6 shadow-card sm:p-8">
        <h1 class="font-display text-2xl font-bold tracking-tight text-ink">Voia admin</h1>
        <p class="mt-1 text-sm text-sand-700">Sign in to view enquiries and chat transcripts.</p>

        <form id="login-form" novalidate class="mt-6 space-y-5">
          <div>
            <label for="email" class={labelClass}>Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="username"
              aria-describedby="login-error"
              class={inputClass}
            />
          </div>
          <div>
            <label for="password" class={labelClass}>Password</label>
            <input
              id="password"
              name="password"
              type="password"
              required
              autocomplete="current-password"
              aria-describedby="login-error"
              class={inputClass}
            />
          </div>

          <p id="login-error" class="hidden items-start gap-1.5 text-sm text-error-700" role="alert" aria-live="assertive">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" class="mt-0.5 h-4 w-4 shrink-0">
              <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <span></span>
          </p>

          <button
            type="submit"
            id="login-submit"
            class="inline-flex w-full min-h-11 items-center justify-center gap-2 rounded-lg bg-coral-600 px-5 font-semibold text-white transition-colors hover:bg-coral-700 active:bg-coral-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none"
          >
            Sign in
          </button>
        </form>
      </div>
    </main>

    <!-- Signed in: header + logout + read-only lists -->
    <div id="signed-in" class="hidden min-h-screen">
      <header class="mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-6 sm:px-8">
        <h1 class="font-display text-2xl font-bold tracking-tight text-ink">Voia admin</h1>
        <button
          type="button"
          id="logout-btn"
          class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg bg-white px-5 font-semibold text-teal-700 ring-1 ring-teal-600 transition-colors hover:bg-teal-50 active:bg-teal-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
        >
          Logout
        </button>
      </header>

      <main class="mx-auto w-full max-w-5xl px-6 pb-16 sm:px-8">
        <section id="enquiries-section" aria-labelledby="enquiries-heading" class="mt-4">
          <h2 id="enquiries-heading" class="font-display text-xl font-semibold tracking-tight text-ink">
            Recent enquiries
          </h2>
          <div id="enquiries-list" class="mt-4"></div>
        </section>

        <section id="transcripts-section" aria-labelledby="transcripts-heading" class="mt-12">
          <h2 id="transcripts-heading" class="font-display text-xl font-semibold tracking-tight text-ink">
            Recent chat transcripts
          </h2>
          <div id="transcripts-list" class="mt-4"></div>
        </section>
      </main>
    </div>
  </body>
</html>

<script>
  import { supabase } from "../lib/supabase";

  const signedOutView = document.getElementById("signed-out") as HTMLElement;
  const signedInView = document.getElementById("signed-in") as HTMLElement;
  const loginForm = document.getElementById("login-form") as HTMLFormElement;
  const loginSubmit = document.getElementById("login-submit") as HTMLButtonElement;
  const loginError = document.getElementById("login-error") as HTMLElement;
  const emailInput = document.getElementById("email") as HTMLInputElement;
  const passwordInput = document.getElementById("password") as HTMLInputElement;
  const logoutBtn = document.getElementById("logout-btn") as HTMLButtonElement;

  function showSignedOut() {
    signedInView.classList.add("hidden");
    signedOutView.classList.remove("hidden");
    signedOutView.classList.add("flex");
  }

  function showSignedIn() {
    signedOutView.classList.add("hidden");
    signedOutView.classList.remove("flex");
    signedInView.classList.remove("hidden");
  }

  function showLoginError(message: string) {
    emailInput.setAttribute("aria-invalid", "true");
    passwordInput.setAttribute("aria-invalid", "true");
    const span = loginError.querySelector("span");
    if (span) span.textContent = message;
    loginError.classList.remove("hidden");
    loginError.classList.add("flex");
  }

  function clearLoginError() {
    emailInput.removeAttribute("aria-invalid");
    passwordInput.removeAttribute("aria-invalid");
    loginError.classList.add("hidden");
    loginError.classList.remove("flex");
  }

  loginForm.addEventListener("submit", async (event) => {
    event.preventDefault();
    clearLoginError();

    const email = emailInput.value.trim();
    const password = passwordInput.value;
    const originalText = loginSubmit.textContent;
    loginSubmit.disabled = true;
    loginSubmit.textContent = "Signing in…";

    const { error } = await supabase.auth.signInWithPassword({ email, password });

    loginSubmit.disabled = false;
    loginSubmit.textContent = originalText;

    if (error) {
      showLoginError("Incorrect email or password. Please try again.");
    }
    // onAuthStateChange below flips the view to signed-in on success.
  });

  logoutBtn.addEventListener("click", async () => {
    await supabase.auth.signOut();
  });

  supabase.auth.onAuthStateChange((_event, session) => {
    if (session) {
      showSignedIn();
    } else {
      showSignedOut();
    }
  });

  supabase.auth.getSession().then(({ data }) => {
    if (data.session) {
      showSignedIn();
    } else {
      showSignedOut();
    }
  });
</script>
