---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DestinationCard from "../../components/DestinationCard.astro";
import FilterBar from "../../components/FilterBar.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { getCollection } from "astro:content";

const destinations = await getCollection("destinations");

function searchHaystack(d: (typeof destinations)[number]): string {
  return [d.data.title, d.data.country, d.data.city ?? "", d.data.tagline, d.data.vibes.join(" "), d.data.activities.join(" ")]
    .join(" ")
    .toLowerCase();
}
---
<BaseLayout
  title="Destinations — Voia"
  description="Explore Voia's destinations — from Romania's Carpathians to Bali's rice terraces. Filter by vibe, region, or season to find your place."
>
    <main id="main-content" class="flex-1">
      <section class="mx-auto max-w-5xl px-6 pb-6 pt-4 sm:px-8">
        <h1 class="text-3xl font-bold tracking-tight text-ink md:text-4xl">Destinations</h1>
        <p class="mt-3 max-w-prose text-lg leading-relaxed text-sand-700">
          Eight places, one for every kind of trip — from a Carpathian fairy tale to a warm-in-winter island. Browse them all, or filter by vibe, region, and season.
        </p>
      </section>

      <section class="mx-auto max-w-5xl px-6 pb-6 sm:px-8">
        <FilterBar mode="destinations" gridId="destinations-grid" />
      </section>

      <section class="mx-auto max-w-5xl px-6 pb-16 sm:px-8">
        <div id="destinations-grid" class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {
            destinations.map((destination, i) => (
              <div
                class="listing-card"
                data-vibes={destination.data.vibes.join(" ")}
                data-region={destination.data.region}
                data-country={destination.data.country.toLowerCase()}
                data-months={destination.data.seasonMonths.join(",")}
                data-title={destination.data.title.toLowerCase()}
                data-search={searchHaystack(destination)}
              >
                <DestinationCard destination={destination} index={i} />
              </div>
            ))
          }
        </div>
      </section>
    </main>

    <SiteFooter />

  <script>
    import { initListingFilters } from "../../scripts/listing-filters";
    initListingFilters("destinations");
  </script>
</BaseLayout>
