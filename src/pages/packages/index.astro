---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PackageCard from "../../components/PackageCard.astro";
import FilterBar from "../../components/FilterBar.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { getCollection, getEntry } from "astro:content";

const packages = await getCollection("packages");

const packagesWithMeta = await Promise.all(
  packages.map(async (pkg) => {
    const destinationEntries = await Promise.all(pkg.data.destinations.map((ref) => getEntry(ref)));
    const regions = new Set(destinationEntries.map((d) => d.data.region));
    const region = regions.size === 1 ? [...regions][0] : "international";
    const countries = [...new Set(destinationEntries.map((d) => d.data.country))];
    const cities = [...new Set(destinationEntries.map((d) => d.data.city).filter((c): c is string => Boolean(c)))];
    const searchHaystack = [
      pkg.data.title,
      pkg.data.tagline,
      pkg.data.vibes.join(" "),
      pkg.data.activities.join(" "),
      countries.join(" "),
      cities.join(" "),
    ]
      .join(" ")
      .toLowerCase();
    return { pkg, region, countries, searchHaystack };
  }),
);
---
<BaseLayout
  title="Trips — Voia"
  description="Voia's curated tour packages — from a five-day Transylvania classic to a Bali winter escape. Filter by vibe, budget, duration, or season. Prices shown are indicative placeholders."
>
    <main id="main-content" class="flex-1">
      <section class="mx-auto max-w-5xl px-6 pb-6 pt-4 sm:px-8">
        <h1 class="text-3xl font-bold tracking-tight text-ink md:text-4xl">Trips</h1>
        <p class="mt-3 max-w-prose text-lg leading-relaxed text-sand-700">
          Six curated trips, budget to splurge. Filter by vibe, budget, duration, or season.
        </p>
        <p class="mt-2 max-w-prose text-sm text-sand-600">
          Prices shown throughout are indicative placeholders, not real quotes — see each trip for details.
        </p>
      </section>

      <section class="mx-auto max-w-5xl px-6 pb-6 sm:px-8">
        <FilterBar mode="packages" gridId="packages-grid" />
      </section>

      <section class="mx-auto max-w-5xl px-6 pb-16 sm:px-8">
        <div id="packages-grid" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            packagesWithMeta.map(({ pkg, region, searchHaystack }, i) => (
              <div
                class="listing-card"
                data-vibes={pkg.data.vibes.join(" ")}
                data-region={region}
                data-months={pkg.data.seasonMonths.join(",")}
                data-duration={pkg.data.durationDays}
                data-price-from={pkg.data.priceFrom}
                data-price-to={pkg.data.priceTo}
                data-title={pkg.data.title.toLowerCase()}
                data-search={searchHaystack}
              >
                <PackageCard pkg={pkg} index={i} />
                <div class="mt-2 flex flex-wrap items-center justify-between gap-x-3 gap-y-1">
                  <p data-est-total hidden class="text-xs font-medium text-sand-600" />
                  <a
                    data-est-enquire
                    href={`/enquire?trip=${encodeURIComponent(pkg.id)}&title=${encodeURIComponent(pkg.data.title)}&adults=1`}
                    class="text-xs font-medium text-teal-700 underline hover:text-teal-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
                  >
                    Enquire about this trip
                  </a>
                </div>
              </div>
            ))
          }
        </div>
      </section>
    </main>

    <SiteFooter />

  <script>
    import { initListingFilters } from "../../scripts/listing-filters";
    initListingFilters("packages");
  </script>
</BaseLayout>
