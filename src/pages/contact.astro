---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";

const inputClass =
  "w-full min-h-11 rounded-lg border border-sand-500 bg-white px-3.5 text-base text-ink placeholder:text-sand-600 transition focus:border-coral-500 focus:outline-none focus:ring-2 focus:ring-coral-500/40";
const labelClass = "block text-sm font-medium text-sand-700 mb-1.5";
const helpClass = "mt-1.5 text-sm text-sand-600";
const errorClass = "mt-1.5 hidden items-start gap-1.5 text-sm text-error-700";
const CONTACT_EMAIL = "alexandrugabrielnicola8@gmail.com";
---
<BaseLayout
  title="Contact — Voia"
  description="General questions, support, or partnerships — get in touch with Voia. For trip enquiries and bookings, see our Enquire page instead."
>
  <main id="main-content" class="flex-1">
    <section class="mx-auto max-w-2xl px-6 pt-8 sm:px-8">
      <h1 class="font-display text-3xl font-bold tracking-tight text-ink md:text-4xl">Contact</h1>
      <p class="mt-2 max-w-prose text-lg text-sand-700">
        General questions, support, or partnerships — we'd love to hear from you.
      </p>
      <p class="mt-2 max-w-prose text-sm text-sand-600">
        Planning a trip and ready to book?{" "}
        <a href="/enquire" class="font-medium text-teal-700 underline hover:text-teal-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2">
          Send a trip enquiry
        </a>{" "}
        instead — it gets you to the right place faster.
      </p>
    </section>

    <section class="mx-auto max-w-2xl px-6 py-8 sm:px-8">
      <noscript>
        <div class="mb-6 rounded-2xl bg-amber-50 p-4 text-sm text-amber-800">
          This form needs JavaScript to send your message. Please enable JavaScript, or email us directly at{" "}
          <a href={`mailto:${CONTACT_EMAIL}`} class="font-medium underline">{CONTACT_EMAIL}</a>.
        </div>
      </noscript>

      <form id="contact-form" novalidate class="space-y-6">
        <!-- Honeypot: real users never see or fill this -->
        <div class="sr-only">
          <label for="company">Leave this field empty</label>
          <input
            type="text"
            id="company"
            name="company"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />
        </div>

        <div>
          <label for="name" class={labelClass}>
            Full name <span class="font-normal text-sand-600">(required)</span>
          </label>
          <input id="name" name="name" type="text" required autocomplete="name" aria-describedby="name-error" class={inputClass} />
          <p id="name-error" class={errorClass} role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" class="mt-0.5 h-4 w-4 shrink-0">
              <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <span>Please enter your name.</span>
          </p>
        </div>

        <div>
          <label for="email" class={labelClass}>
            Email <span class="font-normal text-sand-600">(required)</span>
          </label>
          <input id="email" name="email" type="email" required autocomplete="email" aria-describedby="email-help email-error" class={inputClass} />
          <p id="email-help" class={helpClass}>We'll only use this to reply to you.</p>
          <p id="email-error" class={errorClass} role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" class="mt-0.5 h-4 w-4 shrink-0">
              <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <span>Please enter a valid email address.</span>
          </p>
        </div>

        <div>
          <label for="subject" class={labelClass}>
            Subject <span class="font-normal text-sand-600">(required)</span>
          </label>
          <input id="subject" name="subject" type="text" required aria-describedby="subject-error" class={inputClass} />
          <p id="subject-error" class={errorClass} role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" class="mt-0.5 h-4 w-4 shrink-0">
              <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <span>Please enter a subject.</span>
          </p>
        </div>

        <div>
          <label for="message" class={labelClass}>
            Message <span class="font-normal text-sand-600">(required)</span>
          </label>
          <textarea id="message" name="message" rows="5" required aria-describedby="message-error" class={`${inputClass} min-h-28 py-3`}></textarea>
          <p id="message-error" class={errorClass} role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" class="mt-0.5 h-4 w-4 shrink-0">
              <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <span>Please enter a message.</span>
          </p>
        </div>

        <div>
          <div class="flex items-start gap-2.5">
            <input
              type="checkbox"
              id="consent"
              name="consent"
              required
              aria-describedby="consent-help consent-error"
              class="mt-0.5 h-5 w-5 shrink-0 rounded border-sand-500 text-coral-600 focus:outline-none focus:ring-2 focus:ring-coral-500/40"
            />
            <label for="consent" class="text-sm text-sand-700">
              I agree that Voia can use these details to reply to my message. See our
              <a href="/privacy" class="font-medium text-teal-700 underline hover:text-teal-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2">Privacy Notice</a>.
            </label>
          </div>
          <p id="consent-help" class="mt-1.5 text-xs text-sand-600">Required to send your message.</p>
          <p id="consent-error" class={errorClass} role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" class="mt-0.5 h-4 w-4 shrink-0">
              <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <span>Please agree before sending — this is required.</span>
          </p>
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg bg-coral-600 px-5 font-semibold text-white transition-colors hover:bg-coral-700 active:bg-coral-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none"
        >
          Send message
        </button>
      </form>

      <div id="success-panel" class="hidden rounded-2xl bg-success-50 p-6" role="status">
        <h2 id="success-heading" tabindex="-1" class="font-display text-xl font-semibold tracking-tight text-success-700 focus:outline-none">
          <span data-success-title>Thanks — your message is in.</span>
        </h2>
        <p id="success-body" class="mt-2 text-success-700">
          We'll get back to you by email soon.
        </p>
        <a
          href="/"
          class="mt-4 inline-flex min-h-10 items-center rounded-lg bg-white px-4 text-sm font-semibold text-success-700 ring-1 ring-success-600 transition-colors hover:bg-success-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-success-600 focus-visible:ring-offset-2"
        >
          Back to home
        </a>
      </div>
    </section>
  </main>

  <SiteFooter current="contact" />
</BaseLayout>

<script>
  const CONTACT_EMAIL = "alexandrugabrielnicola8@gmail.com";
  const CONSENT_TEXT = "I agree that Voia can use these details to reply to my message. See our Privacy Notice.";

  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const successPanel = document.getElementById("success-panel") as HTMLElement;
  const successHeading = document.getElementById("success-heading") as HTMLElement;
  const successTitle = document.querySelector("[data-success-title]") as HTMLElement;
  const successBody = document.getElementById("success-body") as HTMLElement;

  const errorInputClasses = ["border-error-600"];
  const errorFocusClasses = ["focus:border-error-600", "focus:ring-error-600/40"];
  const normalInputClasses = ["border-sand-500"];
  const normalFocusClasses = ["focus:border-coral-500", "focus:ring-coral-500/40"];

  function showFieldError(fieldId: string, message: string) {
    const input = document.getElementById(fieldId) as HTMLElement;
    const errorEl = document.getElementById(`${fieldId}-error`);
    input.setAttribute("aria-invalid", "true");
    input.classList.remove(...normalInputClasses, ...normalFocusClasses);
    input.classList.add(...errorInputClasses, ...errorFocusClasses);
    if (errorEl) {
      const span = errorEl.querySelector("span");
      if (span) span.textContent = message;
      errorEl.classList.remove("hidden");
      errorEl.classList.add("flex");
    }
  }

  function clearFieldError(fieldId: string) {
    const input = document.getElementById(fieldId) as HTMLElement;
    const errorEl = document.getElementById(`${fieldId}-error`);
    input.removeAttribute("aria-invalid");
    input.classList.remove(...errorInputClasses, ...errorFocusClasses);
    input.classList.add(...normalInputClasses, ...normalFocusClasses);
    if (errorEl) {
      errorEl.classList.add("hidden");
      errorEl.classList.remove("flex");
    }
  }

  const validatedFields = ["name", "email", "subject", "message", "consent"];

  function clearAllErrors() {
    validatedFields.forEach(clearFieldError);
  }

  function showSuccess(fallback: boolean) {
    form.classList.add("hidden");
    if (fallback) {
      successTitle.textContent = "We've opened your email app to finish sending.";
      successBody.textContent =
        "We couldn't reach our server just now, so we've prefilled an email instead — just hit send there. If nothing opened, email us directly.";
    } else {
      successTitle.textContent = "Thanks — your message is in.";
      successBody.textContent = "We'll get back to you by email soon.";
    }
    successPanel.classList.remove("hidden");
    successHeading.focus();
  }

  function mailtoFallback(name: string, email: string, subject: string, message: string) {
    const body = `${message}\n\n— ${name} (${email})`;
    const url = `mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = url;
  }

  form.addEventListener("submit", async (event: SubmitEvent) => {
    event.preventDefault();
    clearAllErrors();

    const data = new FormData(form);
    const honeypot = (data.get("company") || "").toString().trim();

    const name = (data.get("name") || "").toString().trim();
    const email = (data.get("email") || "").toString().trim();
    const subject = (data.get("subject") || "").toString().trim();
    const message = (data.get("message") || "").toString().trim();
    const consent = data.get("consent") === "on";

    let hasError = false;
    if (!name) {
      showFieldError("name", "Please enter your name.");
      hasError = true;
    }
    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!email || !emailPattern.test(email)) {
      showFieldError("email", "Please enter a valid email address.");
      hasError = true;
    }
    if (!subject) {
      showFieldError("subject", "Please enter a subject.");
      hasError = true;
    }
    if (!message) {
      showFieldError("message", "Please enter a message.");
      hasError = true;
    }
    if (!consent) {
      showFieldError("consent", "Please agree before sending — this is required.");
      hasError = true;
    }

    if (hasError) return;

    // Bot trap: silently pretend success, never insert or email.
    if (honeypot) {
      showSuccess(false);
      return;
    }

    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = "Sending…";

    try {
      const { supabase } = await import("../lib/supabase");
      const { error } = await supabase.from("contact_messages").insert({
        name,
        email,
        subject,
        message,
        consent: true,
        consent_text: CONSENT_TEXT,
      });

      if (error) throw error;
      showSuccess(false);
    } catch (err) {
      // contact_messages may not exist yet (pending SQL — see
      // supabase/contact_messages.sql) — degrade to a prefilled mailto: link
      // rather than losing the message.
      console.error("Contact message insert failed, falling back to mailto:", err);
      mailtoFallback(name, email, subject, message);
      showSuccess(true);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
