---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Voia — Travel the way you feel">
  <div class="flex min-h-screen flex-col">
    <header class="mx-auto flex w-full max-w-5xl items-center px-6 py-4 sm:px-8">
      <a
        href="/"
        class="inline-flex min-h-11 items-center rounded-md font-display text-2xl font-bold tracking-tight text-coral-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2"
      >
        Voia
      </a>
    </header>

    <main class="flex-1">
      <section class="mx-auto max-w-3xl px-6 pb-6 pt-8 text-center sm:px-8 sm:pt-12">
        <h1 class="text-4xl font-bold tracking-tight text-ink md:text-5xl">
          Travel the way you feel.
        </h1>
        <p class="mx-auto mt-4 max-w-prose text-lg leading-relaxed text-sand-700">
          Tell us the kind of trip you're dreaming of — we'll find the place.
        </p>
      </section>
    </main>
  </div>
</BaseLayout>
