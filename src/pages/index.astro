---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Voia — Travel the way you feel">
  <main class="mx-auto flex min-h-screen max-w-2xl flex-col items-center justify-center px-6 text-center">
    <span class="mb-5 inline-block rounded-full bg-coral-50 px-4 py-1.5 text-sm font-medium text-coral-700">
      Coming soon
    </span>
    <h1 class="text-4xl font-bold tracking-tight text-ink md:text-5xl">Voia</h1>
    <p class="mt-3 font-display text-xl text-coral-600 md:text-2xl">
      Travel the way you feel.
    </p>
    <p class="mt-6 max-w-prose text-base leading-relaxed text-sand-700">
      Tell us the kind of trip you're dreaming of — we'll find the place. The vibe
      selector and AI search are on their way.
    </p>
  </main>
</BaseLayout>