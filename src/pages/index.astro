---
import BaseLayout from "../layouts/BaseLayout.astro";

const icons: Record<string, string> = {
  umbrella:
    '<path d="M22 12a10.06 10.06 0 0 0-20 0Z"/><path d="M12 12v8a2 2 0 0 0 4 0"/><path d="M12 2v1"/>',
  mountain: '<path d="m8 3 4 8 5-5 5 15H2L8 3z"/>',
  building2:
    '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/>',
  landmark:
    '<line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/>',
  camera:
    '<path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/>',
  trees:
    '<path d="M10 10v.2A3 3 0 0 1 8.9 16H5a3 3 0 0 1-1-5.8V10a3 3 0 0 1 6 0Z"/><path d="M7 16v6"/><path d="M13 19v3"/><path d="M12 19h8.3a1 1 0 0 0 .7-1.7L18 14h.3a1 1 0 0 0 .7-1.7L16 9h.2a1 1 0 0 0 .8-1.7L13 3l-1.4 1.5"/>',
  compass:
    '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>',
  flower2:
    '<path d="M12 5a3 3 0 1 1 3 3m-3-3a3 3 0 1 0-3 3m3-3v1M9 8a3 3 0 1 0 3 3M9 8h1m5 0a3 3 0 1 1-3 3m3-3h-1m-2 3v-1"/><path d="M12 22c4.2 0 7-1.667 7-5-4.2 0-7 1.667-7 5Z"/><path d="M12 22c-4.2 0-7-1.667-7-5 4.2 0 7 1.667 7 5Z"/><path d="M12 15v7"/><circle cx="12" cy="8" r="2"/>',
};

const tints = [
  { bg: "bg-coral-50", icon: "text-coral-600", title: "text-coral-900", teaser: "text-coral-700" },
  { bg: "bg-teal-50", icon: "text-teal-600", title: "text-teal-900", teaser: "text-teal-700" },
  { bg: "bg-amber-50", icon: "text-amber-700", title: "text-ink", teaser: "text-amber-800" },
  { bg: "bg-sand-100", icon: "text-sand-700", title: "text-ink", teaser: "text-sand-700" },
];

const vibes = [
  { slug: "beach", name: "Beach", icon: "umbrella", teaser: "Sand, sea, and slow days." },
  { slug: "mountain", name: "Mountain", icon: "mountain", teaser: "Peaks, trails, and fresh air." },
  { slug: "city-break", name: "City Break", icon: "building2", teaser: "Cafés, streets, and good chaos." },
  {
    slug: "historical-monuments",
    name: "Historical Monuments",
    icon: "landmark",
    teaser: "Castles, ruins, and old stories.",
  },
  {
    slug: "tourist-attractions",
    name: "Tourist Attractions",
    icon: "camera",
    teaser: "The big sights, worth the trip.",
  },
  {
    slug: "nature-landscapes",
    name: "Nature & Landscapes",
    icon: "trees",
    teaser: "Forests, deltas, and big views.",
  },
  { slug: "adventure", name: "Adventure", icon: "compass", teaser: "A little adrenaline, a lot of yes." },
  {
    slug: "relaxation-wellness",
    name: "Relaxation & Wellness",
    icon: "flower2",
    teaser: "Spa days and deep exhales.",
  },
];
---
<BaseLayout title="Voia — Travel the way you feel">
    <main id="main-content" class="flex-1">
      <section class="mx-auto max-w-3xl px-6 pb-6 pt-8 text-center sm:px-8 sm:pt-12">
        <h1 class="text-4xl font-bold tracking-tight text-ink md:text-5xl">
          Travel the way you feel.
        </h1>
        <p class="mx-auto mt-4 max-w-prose text-lg leading-relaxed text-sand-700">
          Tell us the kind of trip you're dreaming of — we'll find the place.
        </p>
      </section>

      <section class="mx-auto max-w-2xl px-6 pb-10 sm:px-8">
        <form id="ai-search-form" novalidate>
          <label for="ai-search-input" class="sr-only">Describe your dream trip</label>
          <div
            class="rounded-[28px] bg-linear-to-r from-teal-500 to-coral-500 p-[1.5px] shadow-md focus-within:ring-2 focus-within:ring-coral-500 focus-within:ring-offset-2"
          >
            <div class="flex items-center gap-2 rounded-[26px] bg-white p-2 pl-4">
              <span aria-hidden="true" class="shrink-0 text-teal-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/></svg>
              </span>
              <input
                id="ai-search-input"
                name="q"
                type="text"
                autocomplete="off"
                class="min-h-11 w-full min-w-0 bg-transparent text-base text-ink placeholder:text-sand-600 focus:outline-none"
                placeholder="Warm in winter · somewhere like Santorini · mountains and quiet…"
              />
              <button
                type="submit"
                class="inline-flex min-h-11 shrink-0 items-center justify-center gap-2 rounded-xl bg-coral-600 px-4 font-semibold text-white transition-colors hover:bg-coral-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2 sm:px-5"
              >
                <span aria-hidden="true" class="sm:hidden">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
                <span class="hidden sm:inline">Find my trip</span>
                <span class="sr-only sm:hidden">Find my trip</span>
              </button>
            </div>
          </div>

          <div class="mt-3 flex flex-wrap gap-2">
            <button
              type="button"
              data-fill="Warm in winter"
              class="min-h-10 rounded-full bg-sand-100 px-4 text-sm text-sand-700 transition-colors hover:bg-sand-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2"
            >
              Warm in winter
            </button>
            <button
              type="button"
              data-fill="Somewhere like Santorini"
              class="min-h-10 rounded-full bg-sand-100 px-4 text-sm text-sand-700 transition-colors hover:bg-sand-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2"
            >
              Somewhere like Santorini
            </button>
            <button
              type="button"
              data-fill="Mountains &amp; quiet"
              class="min-h-10 rounded-full bg-sand-100 px-4 text-sm text-sand-700 transition-colors hover:bg-sand-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2"
            >
              Mountains &amp; quiet
            </button>
          </div>

          <p
            id="ai-search-note"
            role="status"
            class="mt-3 hidden text-sm font-medium text-teal-700"
          >
            Coming soon — the smart search is on its way.
          </p>
        </form>
      </section>

      <section class="mx-auto max-w-5xl px-6 pb-16 pt-2 sm:px-8">
        <h2 class="mb-5 font-display text-2xl font-semibold tracking-tight text-ink">Pick a vibe</h2>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {
            vibes.map((vibe, i) => {
              const tint = tints[i % tints.length];
              return (
                <a
                  href={`/vibe/${vibe.slug}`}
                  class={`group flex aspect-[4/5] flex-col justify-between rounded-2xl ${tint.bg} p-4 shadow-card transition duration-200 hover:-translate-y-0.5 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2 motion-reduce:transition-none motion-reduce:hover:translate-y-0`}
                >
                  <span
                    class={`grid h-10 w-10 place-items-center rounded-full bg-white ${tint.icon}`}
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={icons[vibe.icon]}
                    />
                  </span>
                  <div>
                    <h3 class={`font-display text-xl font-semibold tracking-tight ${tint.title}`}>
                      {vibe.name}
                    </h3>
                    <p class={`text-sm ${tint.teaser}`}>{vibe.teaser}</p>
                  </div>
                </a>
              );
            })
          }
        </div>
      </section>
    </main>

    <footer class="border-t border-sand-200 px-6 py-8 text-center sm:px-8">
      <p class="font-display text-lg font-semibold text-coral-700">Voia</p>
      <p class="mt-1 text-sm text-sand-700">Travel the way you feel.</p>
      <nav aria-label="Footer" class="mt-3 flex flex-wrap items-center justify-center gap-x-1">
        <a href="/about" class="inline-flex min-h-11 items-center rounded-md px-2 text-sm font-medium text-sand-700 transition-colors hover:text-coral-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2">
          About
        </a>
        <a href="/contact" class="inline-flex min-h-11 items-center rounded-md px-2 text-sm font-medium text-sand-700 transition-colors hover:text-coral-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2">
          Contact
        </a>
      </nav>
      <p class="mt-1 text-xs text-sand-600">A university project.</p>
    </footer>

  <script>
    const form = document.getElementById("ai-search-form") as HTMLFormElement | null;
    const input = document.getElementById("ai-search-input") as HTMLInputElement | null;
    const note = document.getElementById("ai-search-note");

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      note?.classList.remove("hidden");
    });

    form?.querySelectorAll<HTMLButtonElement>("[data-fill]").forEach((chip) => {
      chip.addEventListener("click", () => {
        if (!input) return;
        input.value = chip.dataset.fill ?? "";
        input.focus();
      });
    });
  </script>
</BaseLayout>
