---
import "../styles/global.css";
import ChatWidget from "../components/ChatWidget.astro";
const {
  title = "Voia — Travel the way you feel",
  description = "Voia helps you find a destination by the kind of trip you want — pick a vibe or describe your dream trip in plain words.",
} = Astro.props;

const pathname = Astro.url.pathname;
const isDestinations = pathname.startsWith("/destinations");
const isTrips = pathname.startsWith("/packages");
const isAbout = pathname.startsWith("/about");
const isContact = pathname.startsWith("/contact");

const canonicalURL = new URL(pathname, Astro.site);

const navLinkClass =
  "inline-flex min-h-11 items-center rounded-md px-2 text-sm font-medium text-sand-700 transition-colors hover:text-coral-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2 aria-[current=page]:font-semibold aria-[current=page]:text-coral-700";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Voia" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts: Bricolage Grotesque (display) + Plus Jakarta Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Plus+Jakarta+Sans:wght@400..700&display=swap"
    />
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:left-4 focus-visible:top-4 focus-visible:z-[100] focus-visible:rounded-md focus-visible:bg-white focus-visible:px-4 focus-visible:py-2 focus-visible:text-sm focus-visible:font-semibold focus-visible:text-coral-700 focus-visible:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2"
    >
      Skip to content
    </a>
    <div class="flex min-h-screen flex-col">
      <header class="mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-4 sm:px-8">
        <a
          href="/"
          class="inline-flex min-h-11 items-center rounded-md font-display text-2xl font-bold tracking-tight text-coral-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2"
        >
          Voia
        </a>
        <nav aria-label="Main" class="flex items-center gap-2">
          <a href="/destinations" aria-current={isDestinations ? "page" : undefined} class={navLinkClass}>
            Destinations
          </a>
          <a href="/packages" aria-current={isTrips ? "page" : undefined} class={navLinkClass}>
            Trips
          </a>
          <a href="/about" aria-current={isAbout ? "page" : undefined} class={navLinkClass}>
            About
          </a>
          <a href="/contact" aria-current={isContact ? "page" : undefined} class={navLinkClass}>
            Contact
          </a>
        </nav>
      </header>
      <slot />
    </div>
    <ChatWidget />
  </body>
</html>