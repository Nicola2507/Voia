---
const GREETING = "Hi! I'm your Voia guide. What kind of trip are you in the mood for?";
---

<button
  type="button"
  id="chat-fab"
  aria-expanded="false"
  aria-controls="chat-panel"
  aria-label="Open Voia guide chat"
  class="fixed bottom-5 right-5 z-50 grid h-14 w-14 place-items-center rounded-full bg-coral-600 text-white shadow-lg transition-colors hover:bg-coral-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    focusable="false"
  >
    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
  </svg>
</button>

<div
  id="chat-panel"
  role="dialog"
  aria-label="Voia guide chat"
  aria-modal="false"
  hidden
  class="fixed bottom-24 right-5 z-50 flex w-[min(92vw,380px)] h-[min(70vh,560px)] flex-col overflow-hidden rounded-2xl bg-white shadow-lg"
>
  <div class="flex items-center gap-2.5 bg-teal-600 px-4 py-3 text-white">
    <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-white/20">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
      </svg>
    </span>
    <p class="flex-1 font-display text-base font-semibold tracking-tight">Voia guide</p>
    <button
      type="button"
      id="chat-close"
      aria-label="Close chat"
      class="grid h-11 w-11 shrink-0 place-items-center rounded-full transition-colors hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-teal-600"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>

  <div id="chat-messages" class="flex-1 space-y-3 overflow-y-auto bg-sand-50 p-4">
    <div class="max-w-[80%] rounded-2xl rounded-tl-sm bg-white px-3.5 py-2.5 text-ink shadow-sm">
      {GREETING}
    </div>
  </div>

  <div class="border-t border-sand-200 bg-white px-3 py-2">
    <p class="text-xs text-sand-600">
      Ready to book?
      <a
        href="/contact"
        class="font-medium text-teal-700 underline hover:text-teal-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
      >
        Use our contact form
      </a>
      — please don't share personal details here.
    </p>
  </div>

  <form id="chat-form" class="flex items-center gap-2 border-t border-sand-200 bg-white p-3">
    <label for="chat-input" class="sr-only">Message the Voia guide</label>
    <input
      id="chat-input"
      name="message"
      type="text"
      autocomplete="off"
      maxlength="1000"
      placeholder="Ask about a destination or trip…"
      class="min-h-11 w-full rounded-lg border border-sand-500 bg-white px-3.5 text-base text-ink placeholder:text-sand-600 transition focus:border-coral-500 focus:outline-none focus:ring-2 focus:ring-coral-500/40"
    />
    <button
      type="submit"
      id="chat-send"
      aria-label="Send message"
      class="grid min-h-11 min-w-11 shrink-0 place-items-center rounded-lg bg-coral-600 text-white transition-colors hover:bg-coral-700 active:bg-coral-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        focusable="false"
      >
        <path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"></path>
      </svg>
    </button>
  </form>
</div>

<script>
  type ChatRole = "user" | "bot";
  interface ChatMessage {
    role: ChatRole;
    text: string;
  }

  const GREETING = "Hi! I'm your Voia guide. What kind of trip are you in the mood for?";
  const ERROR_MESSAGE = "Something went wrong — try again, or use /contact.";

  const fab = document.getElementById("chat-fab") as HTMLButtonElement;
  const panel = document.getElementById("chat-panel") as HTMLElement;
  const closeBtn = document.getElementById("chat-close") as HTMLButtonElement;
  const messagesEl = document.getElementById("chat-messages") as HTMLElement;
  const form = document.getElementById("chat-form") as HTMLFormElement;
  const input = document.getElementById("chat-input") as HTMLInputElement;
  const sendBtn = document.getElementById("chat-send") as HTMLButtonElement;

  const history: ChatMessage[] = [{ role: "bot", text: GREETING }];
  let isOpen = false;
  let isSending = false;

  function openPanel() {
    isOpen = true;
    panel.hidden = false;
    fab.setAttribute("aria-expanded", "true");
    input.focus();
    document.addEventListener("keydown", onKeydown);
  }

  function closePanel() {
    isOpen = false;
    panel.hidden = true;
    fab.setAttribute("aria-expanded", "false");
    document.removeEventListener("keydown", onKeydown);
    fab.focus();
  }

  function onKeydown(event: KeyboardEvent) {
    if (event.key === "Escape") closePanel();
  }

  fab.addEventListener("click", () => (isOpen ? closePanel() : openPanel()));
  closeBtn.addEventListener("click", closePanel);

  function appendBubble(role: ChatRole, text: string) {
    const bubble = document.createElement("div");
    if (role === "bot") {
      bubble.className =
        "max-w-[80%] rounded-2xl rounded-tl-sm bg-white px-3.5 py-2.5 text-ink shadow-sm";
    } else {
      bubble.className =
        "ml-auto max-w-[80%] rounded-2xl rounded-tr-sm bg-coral-600 px-3.5 py-2.5 text-white";
    }
    bubble.textContent = text;
    messagesEl.appendChild(bubble);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return bubble;
  }

  function showTyping() {
    const wrap = document.createElement("div");
    wrap.id = "chat-typing";
    wrap.className =
      "flex w-fit items-center gap-1 rounded-2xl rounded-tl-sm bg-white px-3.5 py-3 shadow-sm motion-reduce:gap-1.5";
    wrap.innerHTML = `
      <span class="h-1.5 w-1.5 animate-bounce rounded-full bg-sand-400 motion-reduce:animate-none" style="animation-delay:0ms"></span>
      <span class="h-1.5 w-1.5 animate-bounce rounded-full bg-sand-400 motion-reduce:animate-none" style="animation-delay:150ms"></span>
      <span class="h-1.5 w-1.5 animate-bounce rounded-full bg-sand-400 motion-reduce:animate-none" style="animation-delay:300ms"></span>
    `;
    messagesEl.appendChild(wrap);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function hideTyping() {
    document.getElementById("chat-typing")?.remove();
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (isSending) return;

    const text = input.value.trim();
    if (!text) return;

    appendBubble("user", text);
    history.push({ role: "user", text });
    input.value = "";
    isSending = true;
    input.disabled = true;
    sendBtn.disabled = true;
    showTyping();

    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messages: history }),
      });

      if (!res.ok) throw new Error(`Request failed: ${res.status}`);

      const data = await res.json();
      if (!data.reply) throw new Error("Empty reply");

      hideTyping();
      appendBubble("bot", data.reply);
      history.push({ role: "bot", text: data.reply });
    } catch (err) {
      console.error("Chat request failed:", err);
      hideTyping();
      appendBubble("bot", ERROR_MESSAGE);
    } finally {
      isSending = false;
      input.disabled = false;
      sendBtn.disabled = false;
      input.focus();
    }
  });
</script>
