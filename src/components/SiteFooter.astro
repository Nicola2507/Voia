---
interface Props {
  current?: "about" | "contact" | "enquire";
}

const { current } = Astro.props;

const linkClass =
  "inline-flex min-h-11 items-center rounded-md px-2 text-sm font-medium text-sand-700 transition-colors hover:text-coral-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-coral-500 focus-visible:ring-offset-2 aria-[current=page]:font-semibold aria-[current=page]:text-coral-700";
---
<footer class="border-t border-sand-200 px-6 py-8 text-center sm:px-8">
  <p class="font-display text-lg font-semibold text-coral-700">Voia</p>
  <p class="mt-1 text-sm text-sand-700">Travel the way you feel.</p>
  <nav aria-label="Footer" class="mt-3 flex flex-wrap items-center justify-center gap-x-1">
    <a href="/about" aria-current={current === "about" ? "page" : undefined} class={linkClass}>
      About
    </a>
    <a href="/enquire" aria-current={current === "enquire" ? "page" : undefined} class={linkClass}>
      Enquire
    </a>
    <a href="/contact" aria-current={current === "contact" ? "page" : undefined} class={linkClass}>
      Contact
    </a>
  </nav>
  <p class="mt-1 text-xs text-sand-600">A university project.</p>
</footer>
