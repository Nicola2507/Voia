---
interface Props {
  gallery: { src: string; alt: string }[];
}

const { gallery } = Astro.props;
---
{
  gallery.length > 0 && (
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      {gallery.map((image) => (
        <div class="aspect-[4/3] overflow-hidden rounded-2xl shadow-card">
          <img
            src={image.src}
            alt={image.alt}
            loading="lazy"
            decoding="async"
            width="1600"
            height="1000"
            class="h-full w-full object-cover"
          />
        </div>
      ))}
    </div>
  )
}
