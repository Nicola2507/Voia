---
import VibeIcon from "./VibeIcon.astro";
import { VIBES, type VibeSlug } from "../data/vibes";

interface Props {
  slug: VibeSlug;
  class?: string;
}

const { slug, class: className } = Astro.props;
const vibe = VIBES.find((v) => v.slug === slug);
---
<span
  class:list={[
    "inline-flex items-center gap-1.5 rounded-full bg-sand-100 px-3 py-1 text-sm font-medium text-sand-700",
    className,
  ]}
>
  <VibeIcon slug={slug} class="h-3.5 w-3.5 shrink-0" />
  {vibe?.name}
</span>
